        '200':
          description: HTTP 200 response
          content:
            application/json:
              schema:
                type: string
              example: '+ campaigns (array[Campaign], required)

                + paging (Paging, required)'
        '400':
          description: HTTP 400 response
          content:
            application/json:
              schema:
                type: object
              example:
                error: Invalid parameters
      description: Fetch campaigns by type, with filters for name, date range, and category.
      parameters:
      - name: categoryId
        in: query
        required: false
        schema:
          type: number
        example: '10'
        description: The ID of the category to filter campaigns.
      - name: channel
        in: query
        required: false
        schema:
          type: string
      - name: q
        in: query
        required: false
        schema:
          type: string
        example: christmass
        description: Filter campaigns by name.
      - name: type
        in: query
        required: false
        schema:
          type: string
        example: onetime
        description: Filter campaigns by type
      - name: state
        in: query
        required: false
        schema:
          type: string
      - name: search
        in: query
        required: false
        schema:
          type: string
      - name: dateFrom
        in: query
        required: true
        schema:
          type: string
        example: '2025-05-15'
        description: Start date filter
      - name: dateTo
        in: query
        required: true
        schema:
          type: string
        example: '2025-05-25'
        description: End date filter
      - name: limit
        in: query
        required: false
        schema:
          type: number
        example: '10'
        description: Maximum number of campaigns to return.
      - name: offset
        in: query
        required: false
        schema:
          type: number
        example: '5'
        description: Pagination offset.
      security:
      - bearerAuth: []
  /campaigns/{campaignId}/archive:
    post:
      summary: Archive Campaign
      tags:
      - Campaigns
      responses:
        '200':
          description: HTTP 200 response
        '400':
          description: HTTP 400 response
