                  - id: n4
                    type: delay
                    name: Wait 24 hours
                  - id: n5
                    type: action
                    name: 'Send email #2'
                  edges:
                  - from: n1
                    to: n2
                  - from: n2
                    to: n3
                  - from: n3
                    to: n4
                  - from: n4
                    to: n5
