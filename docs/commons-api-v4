      - AND
      - OR
    TargetCondition:
      type: object
      properties:
        field:
          $ref: '#/components/schemas/TargetField'
          description: Which field to evaluate.
        match:
          $ref: '#/components/schemas/TargetMatchType'
          description: How to compare the field value against `value`.
        value:
          type: string
          example: /products
          description: The expected value to match against.
      required:
      - field
      - match
      - value
      description: A single condition that evaluates one field against one value.
      title: TargetCondition
    TargetGroup:
      type: object
      properties:
        operator:
          $ref: '#/components/schemas/TargetOperator'
          description: Logical operator applied to all items in `conditions`.
          example: AND
        conditions:
          type: array
          description: 'Array of `TargetCondition` objects and/or nested `TargetGroup` objects. Minimum 1 item. Maximum nesting depth: 3 levels. Maximum total nodes across the entire tree: 50.'
          items:
            $ref: '#/components/schemas/TargetNode'
          example:
          - field: url
            match: contains
            value: /products
          - operator: OR
            conditions:
            - field: utmSource
              match: equals
              value: google
            - field: utmSource
              match: equals
              value: facebook
          minItems: 1
      required:
      - operator
      - conditions
      description: 'A logical group that combines conditions and/or nested groups using `AND` or `OR`.


        The tree is evaluated recursively:

        - each `TargetGroup` evaluates its child nodes

        - each `TargetCondition` compares one field value against one expected value


        Node type detection:

        - object with `field` => `TargetCondition`

        - object with `operator` => `TargetGroup`


        Rules:

        - minimum 1 item in `conditions`

        - maximum nesting depth: 3 levels

        - maximum total nodes in the whole tree: 50'
      title: TargetGroup
      example: &id026
        operator: AND
        conditions:
        - field: url
          match: contains
          value: /products
        - operator: OR
          conditions:
          - field: utmSource
            match: equals
            value: google
          - field: utmSource
            match: equals
            value: facebook
      x-examples:
        simple:
          operator: AND
          conditions:
          - field: url
            match: contains
            value: /products
        andOr: *id026
        threeLevelNesting:
          operator: AND
          conditions:
          - field: url
            match: contains
            value: /shop
          - operator: OR
            conditions:
            - operator: AND
              conditions:
              - field: utmSource
                match: equals
                value: google
              - field: device
                match: equals
                value: mobile
            - field: referrerUrl
              match: contains
              value: facebook.com
        multipleUrlPatterns:
          operator: OR
          conditions:
          - field: url
            match: contains
            value: /sale
          - field: url
            match: contains
            value: /promo
          - field: url
            match: regex
            value: ^/products/[0-9]+$
    TargetNode:
      title: TargetNode
      description: 'A node in the target tree.


        Node type detection:

        - object with `field` => `TargetCondition` (leaf node)

        - object with `operator` => `TargetGroup` (composite node)'
      oneOf:
      - $ref: '#/components/schemas/TargetCondition'
      - $ref: '#/components/schemas/TargetGroup'
    Target:
      allOf:
      - $ref: '#/components/schemas/TargetGroup'
      description: 'Target defines the conditions under which a trigger activates.


        It has the same structure as `TargetGroup`, but is exposed as the public type used by API payloads.'
      example: *id026
