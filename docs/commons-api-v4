          items:
            type: string
          description: Tags assigned to the contact.
        fields:
          type: object
          description: Contact`s custom fields JSON
          additionalProperties:
            type: string
        lists:
          type: array
          items:
            type: string
          description: In which mailing lists is the contact. If the list doesn`t exist, it will be created.
    Paging:
      type: object
      properties:
        offset:
          type: number
          example: 21
          description: Start item on the current page
        limit:
          type: number
          example: 40
          description: Number of items on the current page
        totalItems:
          type: number
          example: 100
          description: Total number of items
        totalPages:
          type: number
          example: 5
          description: Total number of pages
        links:
          type: array
          properties:
            href:
              type: string
              example: ?offset=40&limit=60
              description: Link to the page
            rel:
              example: next
              description: Link type
              type: string
              enum:
              - next
              - prev
      description: Pagination information.
    TeaserSettings:
      type: object
      properties:
        position:
          type: object
          properties:
            default:
              type: string
              example: bottomLeft
            positions:
              type: array
              items:
                $ref: '#/components/schemas/TeaserPosition'
          required:
          - positions
        fontFamily:
          type: object
          properties:
            default:
              type: string
              example: Times New Roman
            fontFamilies:
              type: array
              items:
                $ref: '#/components/schemas/TeaserFontFamily'
          required:
          - fontFamilies
        fontWeight:
          type: object
          properties:
            default:
              type: string
              example: normal
            fontWeights:
              type: array
              items:
                $ref: '#/components/schemas/TeaserFontWeight'
          required:
          - fontWeights
        fontSize:
          type: object
          properties:
            default:
              type: string
              example: 16 px
    WebsiteSettings:
      type: object
      properties:
        timezone:
          type: string
          example: Europe/Prague
          description: IANA timezone identifier.
        defaultLanguage:
          type: string
          example: cs
          description: Default language code (ISO 639-1).
        defaultCurrency:
          type: string
          example: CZK
          description: Default currency (ISO 4217).
        dateFormat:
          type: string
          example: YYYY-MM-DD
          description: Display format for dates.
        numberFormat:
          type: string
          example: 1 234,56
          description: Display format for numbers.
        createdAt:
          type: string
          example: '2025-01-10T09:32:15Z'
          description: ISO 8601 timestamp.
        updatedAt:
          type: string
          example: '2025-05-15T10:00:00Z'
          description: ISO 8601 timestamp.
        languages:
          type: array
          items:
            type: string
        currencies:
          type: array
          items:
            type: string
    ErrorResponse:
      type: object
      properties:
        error:
          type: string
      required:
      - error
