        '404':
          description: HTTP 404 response
      description: Clone an existing campaign.
      parameters:
      - name: campaignId
        in: path
        required: true
        schema:
          type: string
        description: Unique identifier of the campaign.
      security:
      - bearerAuth: []
      operationId: post_campaigns_campaignId_duplicate
  /campaigns/{campaignId}:
    delete:
