openapi: 3.0.3
info:
  title: Incomaker Commons v4
  version: 4.0.0
  description: Best-effort OpenAPI conversion from API Blueprint.
servers:
- url: https://commons.incomaker.com/v4
paths:
  /socialaccounts:
    get:
      summary: Get Accounts
      tags:
      - Social Accounts
      responses:
        '200':
          description: HTTP 200 response
        '400':
          description: HTTP 400 response
          content:
            application/json:
              schema:
                type: object
              example:
                error: Invalid parameters `type`
      parameters:
      - name: active
        in: query
        required: false
        schema:
          type: boolean
        example: 'true '
      - name: type
        in: query
        required: false
        schema:
          type: string
      - name: network
        in: query
        required: false
        schema:
          type: string
      - name: q
        in: query
        required: false
        schema:
          type: string
        description: Filter accounts by name.
      - name: limit
        in: query
        required: false
        schema:
          type: number
        example: '10'
        description: Maximum number of campaigns to return.
      - name: offset
        in: query
        required: false
        schema:
          type: number
        example: '0'
        description: Pagination offset.
      security:
      - bearerAuth: []
  /adaccounts/facebook:
    get:
      summary: Get Accounts for Facebook
      tags:
      - Ad Accounts
      responses:
        '200':
          description: HTTP 200 response
        '400':
          description: HTTP 400 response
          content:
            application/json:
              schema:
                type: object
              example:
                error: Invalid parameters `type`
      description: Fetch advertising accounts with filters for network, name or type.
      parameters:
      - name: socialaccount
        in: query
        required: true
        schema:
          type: string
        example: ffa27357
        description: facebook`s account id
      - name: limit
        in: query
        required: false
        schema:
          type: number
        example: '10'
        description: Maximum number of campaigns to return.
      - name: offset
        in: query
        required: false
        schema:
          type: number
        example: '0'
        description: Pagination offset.
      security:
      - bearerAuth: []
  /assets/email/generate:
    post:
      summary: Generate e-mail content (AI)
      tags:
      - Assets
      responses:
        '200':
          description: HTTP 200 response
          content:
            application/json:
              schema:
                type: object
                properties:
                  result:
                    type: object
                    properties:
                      subject:
                        type: string
                      preheader:
                        type: string
                      html:
                        type: string
                      text:
                        type: string
                    required:
                    - subject
                    - html
                    - text
                  meta:
                    type: object
                    properties:
                      model:
                        type: string
                      generatedAt:
                        type: string
                        format: date-time
                      language:
                        type: string
                    required:
                    - model
                    - generatedAt
                    - language
                required:
                - result
                - meta
        '400':
          description: HTTP 400 response
          content:
            application/json:
              schema:
                type: string
              example: "```json\n{\n  \"error\": \"Invalid parameters: missing language or inputs.brief\"\n}\n```"
        '403':
          description: HTTP 403 response
          content:
            application/json:
              schema:
                type: string
              example: "```json\n{\n  \"error\": \"You don’t have permission to generate AI content.\"\n}\n```"
        '422':
          description: HTTP 422 response
          content:
            application/json:
              schema:
                type: string
              example: "```json\n{\n  \"error\": \"Unable to generate content\",\n  \"details\": {\n    \"reason\": \"prompt_too_long\"\n  }\n}\n```"
      description: Generate draft email content (subject, optional preheader, HTML body and plain-text version) using AI based on campaign context, target audience, selected products and custom instructions.
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                language:
                  type: string
                  description: ISO 639-1 language code of the output
                  example: cs
                tone:
                  type: string
                  description: Desired tone/style (e.g. sales, friendly, urgent, informational)
                  example: sales
                context:
                  type: object
                  properties:
                    campaignId:
                      type: string
                      example: c_1001
                    campaignType:
                      type: string
                      example: onetime
                    channel:
                      type: string
                      example: email
                  required:
                  - campaignId
                  - campaignType
                  - channel
                audience:
                  type: object
                  properties:
                    audienceId:
                      type: string
                      description: UUID of the target audience/segment
                      example: 0469ab2c-9ee4-4923-a470-9fbebbbb5252
                  required:
                  - audienceId
                products:
                  type: object
                  properties:
                    productIds:
                      type: array
                      items:
                        type: number
                      description: List of product IDs from the e-commerce catalog
                    limit:
                      type: number
                      description: Max number of products to reference/include
                      example: 6
                constraints:
                  type: object
                  properties:
                    maxSubjectLength:
                      type: number
                      description: Maximum allowed length of subject line
                      example: 55
                    includePreheader:
                      type: boolean
                      description: Whether to generate preheader text
                      example: true
                inputs:
                  type: object
                  properties:
                    brief:
                      type: string
                      description: Main instruction and copy direction for the AI
                      example: 'Výprodej zimní kolekce, zdůraznit dopravu zdarma nad 1 500 Kč. CTA: Nakoupit se slevou.'
                    brandName:
                      type: string
                      description: Brand name to use in the copy
                      example: Incomaker Shop
                  required:
                  - brief
              required:
              - language
              - context
              - audience
              - inputs
            example:
              language: cs
              tone: sales
              context:
                campaignId: c_1001
                campaignType: onetime
                channel: email
              audience:
                audienceId: 0469ab2c-9ee4-4923-a470-9fbebbbb5252
              products:
                productIds: []
                limit: 6
              constraints:
                maxSubjectLength: 55
                includePreheader: true
              inputs:
                brief: 'Výprodej zimní kolekce, zdůraznit dopravu zdarma nad 1 500 Kč. CTA: Nakoupit se slevou.'
                brandName: Incomaker Shop
      operationId: post_assets_email_generate
  /audiences:
    get:
      summary: Get Audiences
      tags:
      - Audiences
      responses:
        '200':
          description: HTTP 200 response
        '400':
          description: HTTP 400 response
          content:
            application/json:
              schema:
                type: object
              example:
                error: Invalid parameters `type`
      description: Fetch audiences by type, with filters for name, date range, and category.
      parameters:
      - name: type
        in: query
        required: false
        schema:
          type: string
        example: incomaker
      - name: state
        in: query
        required: false
        schema:
          type: string
        example: paused,invalid
      - name: q
        in: query
        required: false
        schema:
          type: string
        example: hollydays
        description: Filter audiences by name.
      - name: limit
        in: query
        required: false
        schema:
          type: number
        example: '20 '
        description: Maximum number of campaigns to return.
      - name: offset
        in: query
        required: false
        schema:
          type: number
        example: '5 '
        description: Pagination offset.
      security:
      - bearerAuth: []
  /campaigns:
