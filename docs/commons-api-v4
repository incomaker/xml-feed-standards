        schema:
          type: string
        description: Unique identifier of the campaign.
      security:
      - bearerAuth: []
      operationId: post_campaigns_campaignId_archive
  /campaigns/{campaignId}/{action}:
    post:
      summary: Pause/Resume/Cancel Campaign
      tags:
      - Campaigns
      responses:
        '200':
          description: HTTP 200 response
        '400':
          description: HTTP 400 response
          content:
            application/json:
              schema:
                type: object
                properties:
                  error:
                    type: string
              example:
                error: Action not allowed
      description: Change a campaign’s running state. Replace `{action}` with `pause`, `resume`, or `cancel`.
      parameters:
      - name: campaignId
        in: path
        required: true
        schema:
          type: string
        description: Unique identifier of the campaign.
      - name: action
        in: path
        required: true
        schema:
          type: string
        description: Action to perform (`pause`, `resume`, `cancel`).
      security:
      - bearerAuth: []
      operationId: post_campaigns_campaignId_action
  /campaigns/{campaignId}/rename:
    put:
